{{define "title"}}Home{{ end }}
{{define "page-intro"}}
<p>Hello! I'm Ryan Nicoletti, welcome to my personal website. I'm a software developer and veterinarian. I post my thoughts about both industries and whatever else may interest me here.</p>
{{ end }}
{{define "main"}}
<h1>Posts</h1>
<ul>
{{ range.Posts }}
<li>
  <article>
    <a class="post-link" href="/post/{{.Slug}}">{{.Title}}</a>
    <time datetime="{{.Created.Format "2006-01-02"}}">({{.Created.Format "02 January 2006"}})</time>
  </article>
</li>
{{ end }}
</ul>
{{ end }}

{{define "title"}}post{{ end }}

{{define "main"}}
<article class="blog-post">
  <header>
    <h1>{{.Post.Title}}</h1>
     <time datetime="{{.Post.Created.Format "2006-01-02"}}">
            {{.Post.Created.Format "January 2, 2006"}}
        </time>
  </header>
  <div class="post-content">
        {{.Post.Content | html}}
    </div>
</article>
<section class="comments-section">
    <h2>Comments</h2>
</section>
{{ end }}

{{define "title"}}post{{ end }}
{{define "header"}}{{.Post.Title}}{{ end }}
{{define "main"}}
<article class="blog-post">
  <header>
     <time datetime="{{.Post.Created.Format "2006-01-02"}}">
            {{.Post.Created.Format "02 January 2006"}}
        </time>
  </header>
  <div class="post-content">
        {{.Post.Content}}
    </div>
</article>
<section class="comments-section">
    <h2>Comments</h2>
    <p id="add-comment-btn">add a comment</p>
    <form action="/comment/create" method="POST" id="add-comment-form" class="hidden">
        <div>
            <label>Name</label>
            <input type="text" name="name">
        </div>
        <div>
            <label>Website/Social Media (optional)</label>
            <input type="text" name="website">
        </div>
        <div>
            <label>Comment</label>
            <textarea name="comment"></textarea>
        </div>
        <div>
            <input type='submit' value='submit'>
        </div>
        <div>
            <p id="cancel-comment-btn">cancel</p>
        </div>
    </form>
</section>
    <script src="../../static/js/comments.js" type="text/javascript"></script>
{{ end }}
